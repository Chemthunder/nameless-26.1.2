{
  "model": {
    "type": "minecraft:condition",
    "on_false": {
      "type": "minecraft:select",
      "cases": [
        {
          "model": {
            "type": "minecraft:model",
            "model": "nameless:item/nameless"
          },
          "when": [
            "gui",
            "ground",
            "fixed",
            "on_shelf"
          ]
        }
      ],
      "fallback": {
        "type": "minecraft:model",
        "model": "nameless:item/nameless_in_hand"
      },
      "property": "minecraft:display_context"
    },
    "on_true": {
      "type": "minecraft:select",
      "cases": [
        {
          "model": {
            "type": "minecraft:model",
            "model": "nameless:item/nameless_covered"
          },
          "when": [
            "gui",
            "ground",
            "fixed",
            "on_shelf"
          ]
        }
      ],
      "fallback": {
        "type": "minecraft:model",
        "model": "nameless:item/nameless_covered_in_hand"
      },
      "property": "minecraft:display_context"
    },
    "property": "nameless:covered"
  }
}